#!/bin/bash
# Wakka Cache Helper
# Este script es llamado por pkexec para ejecutar limpiezas del sistema.

ACTION="$1"
shift

find_paccache() {
    command -v paccache 2>/dev/null || true
}

case "$ACTION" in
    clean-pacman-cache)
        PACCACHE_BIN="$(find_paccache)"
        if [ -z "$PACCACHE_BIN" ]; then
            echo "paccache no está instalado (instala pacman-contrib)"
            exit 1
        fi
        KEEP="${1:-2}"
        exec "$PACCACHE_BIN" -r "-k${KEEP}"
        ;;
    clean-pacman-uninstalled)
        PACCACHE_BIN="$(find_paccache)"
        if [ -z "$PACCACHE_BIN" ]; then
            echo "paccache no está instalado (instala pacman-contrib)"
            exit 1
        fi
        exec "$PACCACHE_BIN" -ruk0
        ;;
    clean-orphans)
        ORPHANS="$(/usr/bin/pacman -Qdtq)"
        if [ -z "$ORPHANS" ]; then
            echo "No hay paquetes huérfanos."
            exit 0
        fi
        exec /usr/bin/pacman -Rns --noconfirm $ORPHANS
        ;;
    clean-all)
        KEEP="${1:-2}"
        PACCACHE_BIN="$(find_paccache)"
        if [ -n "$PACCACHE_BIN" ]; then
            echo "Limpiando versiones antiguas de caché..."
            "$PACCACHE_BIN" -r "-k${KEEP}"
            echo "Limpiando caché de paquetes desinstalados..."
            "$PACCACHE_BIN" -ruk0
        fi
        ORPHANS="$(/usr/bin/pacman -Qdtq)"
        if [ -n "$ORPHANS" ]; then
            echo "Eliminando paquetes huérfanos..."
            /usr/bin/pacman -Rns --noconfirm $ORPHANS
        fi
        echo "Limpieza del sistema completada."
        ;;
    *)
        echo "Acción no válida: $ACTION"
        exit 1
        ;;
esac
