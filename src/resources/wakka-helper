#!/bin/bash
# Wakka Package Manager Helper
# Este script es llamado por pkexec para ejecutar operaciones de yay

ACTION="$1"

run_yay_with_elevation() {
    local REAL_UID="$1"
    local REAL_USER
    REAL_USER=$(id -nu "$REAL_UID")
    local REAL_HOME
    REAL_HOME=$(getent passwd "$REAL_UID" | cut -d: -f6)
    shift
    
    local SUDOERS_FILE="/etc/sudoers.d/wakka-temp-$REAL_USER"
    
    # Crear regla temporal de sudoers para que yay no pida contraseña al llamar a pacman
    echo "$REAL_USER ALL=(ROOT) NOPASSWD: /usr/bin/pacman" > "$SUDOERS_FILE"
    chmod 440 "$SUDOERS_FILE"
    
    # Limpieza al salir
    trap "rm -f $SUDOERS_FILE" EXIT INT TERM
    
    # Ejecutar yay como usuario real
    sudo -u "$REAL_USER" /usr/bin/yay --answerdiff None --answerclean None --answerupgrade None "$@" --builddir "$REAL_HOME/.cache/yay"

    rm -f "$SUDOERS_FILE"
    trap - EXIT INT TERM
}

case "$ACTION" in
    pk-sudo)
        shift
        "$@"
        ;;
    install)
        REAL_UID=$PKEXEC_UID
        if [ -n "$REAL_UID" ]; then
            run_yay_with_elevation "$REAL_UID" -Sy --noconfirm --needed "${@:2}"
        else
            shift
            /usr/bin/yay --answerdiff None --answerclean None --answerupgrade None -Sy --noconfirm --needed "$@"
        fi
        ;;
    remove)
        shift
        for PKG in "$@"; do
            if [[ "$PKG" == *" (AppImage)" ]]; then
                CLEAN_NAME=$(echo "$PKG" | sed "s/ (AppImage)//" | tr "[:upper:]" "[:lower:]")
                DESKTOP="/usr/share/applications/${CLEAN_NAME}.desktop"
                if [ -f "$DESKTOP" ]; then
                    OPT_DIR=$(grep "Exec=" "$DESKTOP" | cut -d= -f2 | sed "s/\"//g" | xargs dirname)
                    rm -rf "$OPT_DIR"
                    rm -f "$DESKTOP"
                    echo "AppImage $PKG eliminada correctamente."
                else
                    echo "No se encontró el archivo .desktop para $PKG"
                fi
            else
                REAL_UID=$PKEXEC_UID
                if [ -n "$REAL_UID" ]; then
                    run_yay_with_elevation "$REAL_UID" -Rns --noconfirm "$PKG"
                else
                    /usr/bin/yay --answerdiff None --answerclean None --answerupgrade None -Rns --noconfirm "$PKG"
                fi
            fi
        done
        ;;
    update)
        REAL_UID=$PKEXEC_UID
        if [ -n "$REAL_UID" ]; then
            run_yay_with_elevation "$REAL_UID" -Syu --noconfirm "${@:2}"
        else
            shift
            /usr/bin/yay --answerdiff None --answerclean None --answerupgrade None -Syu --noconfirm "$@"
        fi
        ;;
    install-local)
        FILE_PATH="$2"
        if [[ "$FILE_PATH" == *.deb ]] || [[ "$FILE_PATH" == *.rpm ]]; then
            echo "--- Converting foreign package ---"
            # Llamar al conversor (ajusta la ruta según instalación)
            RESULT=$(python3 /home/jhon/Desarrollos/Wakka/src/core/package_converter.py convert "$FILE_PATH" | grep "RESULT:" | cut -d: -f2)
            if [ -n "$RESULT" ] && [ -f "$RESULT" ]; then
                /usr/bin/pacman -U --noconfirm "$RESULT"
                rm -f "$RESULT"
            else
                echo "Error en la conversión"
                exit 1
            fi
        elif [[ "$FILE_PATH" == *.AppImage ]]; then
            echo "--- Installing AppImage ---"
            python3 /home/jhon/Desarrollos/Wakka/src/core/package_converter.py appimage "$FILE_PATH"
        else
            REAL_UID=$PKEXEC_UID
            if [ -n "$REAL_UID" ]; then
                run_yay_with_elevation "$REAL_UID" -U --noconfirm "${@:2}"
            else
                shift
                /usr/bin/yay --answerdiff None --answerclean None --answerupgrade None -U --noconfirm "$@"
            fi
        fi
        ;;
    clean)
        REAL_UID=$PKEXEC_UID
        if [ -n "$REAL_UID" ]; then
            run_yay_with_elevation "$REAL_UID" -Yc --noconfirm "${@:2}"
        else
            shift
            /usr/bin/yay --answerdiff None --answerclean None --answerupgrade None -Yc --noconfirm "$@"
        fi
        ;;
    refresh)
        /usr/bin/pacman -Sy --noconfirm
        ;;
    download)
        REAL_UID=$PKEXEC_UID
        if [ -n "$REAL_UID" ]; then
            if [ $# -le 1 ]; then
                run_yay_with_elevation "$REAL_UID" -Syuw --noconfirm
            else
                run_yay_with_elevation "$REAL_UID" -Sy --noconfirm
                run_yay_with_elevation "$REAL_UID" -Sw --noconfirm "${@:2}"
            fi
        else
            shift
            if [ $# -eq 0 ]; then
                /usr/bin/yay --answerdiff None --answerclean None --answerupgrade None -Syuw --noconfirm
            else
                /usr/bin/yay --answerdiff None --answerclean None --answerupgrade None -Sw --noconfirm "$@"
            fi
        fi
        ;;
    unlock)
        /usr/bin/rm -f /var/lib/pacman/db.lck
        ;;
    apply-pacman-conf)
        /usr/bin/cp "$1" /etc/pacman.conf
        ;;
    set-shutdown-service)
        /usr/bin/systemctl "$1" wakka-shutdown.service
        ;;
    kill)
        /usr/bin/kill -9 "$1"
        ;;
    *)
        echo "Acción no válida: $ACTION"
        exit 1
        ;;
esac
